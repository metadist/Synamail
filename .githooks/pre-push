#!/usr/bin/env -S env LC_ALL=C.UTF-8 LANG=C.UTF-8 bash
# See pre-commit for the rationale on this shebang.
#
# Synamail — pre-push hook. This is the LAST line of defence before code
# reaches GitHub, so it runs the SAME gate CI runs ('make ci-local'). A commit
# made through a tool that skipped pre-commit (IDE auto-commit, `--no-verify`)
# is still caught here. It also reminds you to run E2E for auth/view changes.
#
# Bypass only in a genuine emergency with `git push --no-verify`, and never to
# main — see docs/COMMIT_PROCESS.md and AGENTS.md.

set -e

# Print informational progress only to interactive terminals — see pre-commit
# for the rationale.
info() {
  if [ -t 1 ]; then
    printf '%s\n' "$*"
  fi
}

cd "$(git rev-parse --show-toplevel)"

strict="${SYNAMAIL_PRE_PUSH_STRICT:-0}"

# --- Hard gate: exactly what CI's build job runs --------------------------
if [ -f package.json ]; then
  if command -v make >/dev/null 2>&1; then
    info "[pre-push] running 'make ci-local' (mirrors GitHub CI)"
    make ci-local
  else
    echo "[pre-push] 'make' not found — cannot run the local gate; install make or fix CI may fail." >&2
    exit 1
  fi
fi

# git pushes pass refs on stdin: <local ref> <local sha> <remote ref> <remote sha>
changed=""
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue  # deleting a ref
  fi
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # New branch — compare against the upstream of HEAD if known.
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi
  changed="$changed $(git diff --name-only "$range" || true)"
done

if [ -z "$changed" ]; then
  exit 0
fi

trigger_paths=(
  'src/taskpane/composables/useAuth\.ts'
  'src/dialog/'
  'src/shared/synaplan-client\.ts'
  'src/taskpane/views/'
  'manifest\.xml'
)

needs_e2e=false
for p in "${trigger_paths[@]}"; do
  if echo "$changed" | tr ' ' '\n' | grep -qE "$p"; then
    needs_e2e=true
    break
  fi
done

if $needs_e2e; then
  msg="[pre-push] auth / client / view / manifest changed — run 'make test-e2e' before merging"
  if [ "$strict" = "1" ]; then
    echo "$msg" >&2
    exit 1
  else
    info "$msg"
  fi
fi

exit 0
