<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!--
    Synamail — PRODUCTION manifest for the AppSource submission.

    Hosting layout on https://addin.synaplan.com:
      /src/taskpane/taskpane.html   (Vite build output, dist/ served at root)
      /src/commands/commands.html
      /assets/icon-*.png            (copied next to dist/ on deploy)

    The dev manifest is manifest.xml (localhost:3000). `make validate`
    checks both; `make build-manifest` converts THIS file to the unified
    JSON manifest for the store submission.

    Naming convention: manifest_<major>-<minor>-<patch>_prod.xml — rename the
    file when bumping <Version> so the uploaded package is unambiguous.
  -->

  <Id>342cee66-dd27-471d-b2ac-fa1bbb5db54f</Id>
  <Version>1.0.2.1</Version>
  <ProviderName>Synaplan</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Synamail AI" />
  <Description DefaultValue="Your Synaplan workspace inside Outlook. Summarise, translate, draft replies, save emails to your knowledge base, build AI profiles of your contacts, and ask follow-ups — all without leaving Outlook." />
  <IconUrl DefaultValue="https://addin.synaplan.com/assets/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://addin.synaplan.com/assets/icon-128.png" />
  <SupportUrl DefaultValue="https://www.synaplan.com/" />

  <AppDomains>
    <!-- Sign-in dialog origin (Office.context.ui.displayDialogAsync). Users on
         self-hosted Synaplan instances type their own URL; Office prompts for
         those domains at sign-in time. -->
    <AppDomain>https://web.synaplan.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.8" />
    </Sets>
  </Requirements>

  <!-- FormSettings MUST declare a Form for every FormType listed in the Rule
       below. The Rule includes FormType="Edit", so an ItemEdit form is
       REQUIRED: Outlook on the web / new Outlook validate the base manifest
       server-side and silently drop the whole compose surface (reply/new mail
       ribbon button) when the ItemEdit form is missing — while classic
       Outlook, which builds its ribbon purely from VersionOverrides, still
       shows it. Keep both forms in sync with the dev manifest. -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://addin.synaplan.com/src/taskpane/taskpane.html" />
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://addin.synaplan.com/src/taskpane/taskpane.html" />
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- ReadWriteItem is enough: v1 reads items, opens reply/appointment forms,
       and uses roaming settings. No EWS / mailbox-wide access. -->
  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.8">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url" />

          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="GroupLabel" />
                <Control xsi:type="Button" id="msgReadOpenPaneButton">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgComposeGroup">
                <Label resid="GroupLabel" />
                <Control xsi:type="Button" id="msgComposeOpenPaneButton">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://addin.synaplan.com/assets/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://addin.synaplan.com/assets/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://addin.synaplan.com/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://addin.synaplan.com/src/commands/commands.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://addin.synaplan.com/src/taskpane/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Synamail AI" />
        <bt:String id="TaskpaneButton.Label" DefaultValue="Open Synamail AI" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the Synamail assistant to summarise, translate, draft replies, save emails to your knowledge base, profile your contacts, or ask follow-up questions." />
      </bt:LongStrings>
    </Resources>

    <!-- NOTE: no nested VersionOverridesV1_1 block. We previously nested one
         to add SupportsPinning, but that structure makes the ribbon button
         silently dead on M365 business accounts in Outlook on the web / new
         Outlook (no network request, no error) — see
         https://github.com/OfficeDev/office-js/issues/5902. A working task
         pane beats a pinnable one, so pinning is dropped until the platform
         bug is fixed. -->
  </VersionOverrides>
</OfficeApp>
