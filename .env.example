# Synamail dev-only build flags. Copy to `.env.local` (gitignored) to use.
#
# There are NO runtime VITE_* config values in Synamail — the manifest is
# shipped to users and the Synaplan base URL is configured at runtime via
# Settings. The only env flags are dev-loop conveniences that never enter the
# production bundle.

# Use the real local Synaplan sign-in (`<baseUrl>/addin/connect`) instead of
# the offline mock relay. Set to "false" to get a REAL API key from your local
# stack (RealSynaplanClient); leave unset/anything-else for the instant mock.
VITE_DEV_MOCK_AUTH=false
