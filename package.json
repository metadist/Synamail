{
  "name": "synamail",
  "version": "0.1.0",
  "private": true,
  "description": "Synamail - Outlook add-in for Synaplan",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "vite",
    "build": "vue-tsc -b --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0 && prettier --check \"**/*.{ts,vue,json,md,html,css,yml,yaml}\"",
    "format": "prettier --write \"**/*.{ts,vue,json,md,html,css,yml,yaml}\" && eslint . --fix",
    "check:types": "vue-tsc -b --noEmit",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:component": "vitest run tests/component",
    "test:e2e": "playwright test",
    "validate": "office-addin-manifest validate manifest.xml",
    "sideload": "office-addin-debugging start manifest.xml",
    "stop-sideload": "office-addin-debugging stop manifest.xml",
    "build-manifest": "office-addin-manifest-converter convert manifest.prod.xml -o manifest.unified.json",
    "generate:schemas": "echo 'Schema generation lands in Sprint 3 - see docs/FEATURES.md section 6.' && exit 0"
  },
  "dependencies": {
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6",
    "zod": "^4.4.3"
  },
  "overrides": {
    "strip-bom": "3.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "@types/office-js": "^1.0.592",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "office-addin-debugging": "^6.1.1",
    "office-addin-dev-certs": "^2.0.7",
    "office-addin-manifest": "^2.1.3",
    "office-addin-manifest-converter": "^0.4.1",
    "office-addin-validator": "^1.0.5",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
