{
  "name": "synamail",
  "version": "0.1.0",
  "private": true,
  "description": "Synamail — Outlook add-in for Synaplan",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0 && prettier --check \"**/*.{ts,vue,json,md,html,css,yml,yaml}\"",
    "format": "prettier --write \"**/*.{ts,vue,json,md,html,css,yml,yaml}\" && eslint . --fix",
    "check:types": "vue-tsc -b --noEmit",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:component": "vitest run tests/component",
    "test:e2e": "playwright test",
    "validate": "office-addin-manifest validate manifest.xml",
    "sideload": "office-addin-debugging start manifest.xml",
    "stop-sideload": "office-addin-debugging stop manifest.xml",
    "build-manifest": "office-addin-manifest-converter convert manifest.xml -o manifest.unified.json",
    "generate:schemas": "echo 'Schema generation lands in Sprint 3 — see docs/FEATURES.md §6.' && exit 0"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-i18n": "^9.14.0",
    "zod": "^3.23.0"
  },
  "overrides": {
    "strip-bom": "3.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@playwright/test": "^1.47.0",
    "@types/node": "^25.9.1",
    "@types/office-js": "^1.0.450",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.10.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^15.9.0",
    "jsdom": "^25.0.0",
    "office-addin-debugging": "^6.1.1",
    "office-addin-dev-certs": "^2.0.7",
    "office-addin-manifest": "^2.1.3",
    "office-addin-manifest-converter": "^0.4.1",
    "office-addin-validator": "^1.0.5",
    "prettier": "^3.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "vue-tsc": "^3.3.1"
  }
}
