# =============================================================================
# In-image static server for the Synamail add-in (NOT the the host ingress proxy).
#
# Serves the built add-in on :80. The the host Caddy proxy reverse-proxies
# addin.synaplan.com -> synamail-addin:80; Cloudflare terminates TLS upstream.
# =============================================================================
{
	admin off
	auto_https off
}

:80 {
	encode zstd gzip

	# Lightweight liveness endpoint used by the compose healthcheck.
	@health path /healthz
	handle @health {
		respond "ok" 200
	}

	# Build stamp — served uncached so a freshness check is always accurate.
	@version path /version.json
	handle @version {
		root * /srv
		header Access-Control-Allow-Origin "*"
		header Cache-Control "no-store"
		file_server
	}

	handle {
		root * /srv
		header {
			# Outlook embeds the taskpane + auth relay in an iframe; never block it.
			-X-Frame-Options
			# Let Outlook hosts load static assets (icons, JS) cross-origin.
			Access-Control-Allow-Origin "*"
			# Short cache so a redeploy is picked up quickly; payload is tiny.
			Cache-Control "public, max-age=300"
		}
		file_server
	}
}
